{
	"info": {
		"_postman_id": "smim-backend-api-collection",
		"name": "SMIM Backend API",
		"description": "SMIM (Smart Media Insight Manager) 백엔드 API 컬렉션\n\n## 사용 방법\n1. Environment에서 `baseUrl` 변수를 설정하세요 (기본값: http://localhost:8080)\n2. OAuth2 로그인 후 받은 Access Token을 `accessToken` 변수에 저장하세요\n3. 인증이 필요한 API는 자동으로 Authorization 헤더가 추가됩니다",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "OAuth2 - Google Login",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/oauth2/authorize/google",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"oauth2",
								"authorize",
								"google"
							]
						},
						"description": "Google OAuth2 로그인을 시작합니다.\n브라우저에서 이 URL을 열어 로그인하세요."
					},
					"response": []
