							"body": "{\n  \"id\": 1,\n  \"email\": \"user@example.com\",\n  \"name\": \"홍길동\",\n  \"profileImage\": \"https://lh3.googleusercontent.com/a/example\",\n  \"provider\": \"GOOGLE\",\n  \"role\": \"USER\",\n  \"createdAt\": \"2024-01-15T10:30:00\"\n}"
						}
